# API keys and secrets — never commit these
.env
.env.local
.env.*.local

# Python cache
__pycache__/
*.pyc
*.pyo

# Node dependencies (Playwright etc.) — reinstallable, never commit
node_modules/

# Stray Windows reserved-name artifact (git cannot index it)
nul

# Editor / OS noise
.DS_Store
Thumbs.db
desktop.ini
*.swp

# Playwright MCP debug captures (investigation artefacts, not project code)
.playwright-mcp/

# Raw API response dumps — large, derivable by re-running fetch_odds.py
data/**/*_raw.json

# Screenshots and debug images
*.png

# Session transcripts
Claude_last_session_PowerShell.txt
claude_code_PS_last.txt
